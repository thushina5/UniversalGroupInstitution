                "html": "<!-- Replace with Elementor Pro Form widget, or a Contact Form 7 / WPForms shortcode. Basic fallback form below posts to the custom theme handler. -->\n<form action=\"/wp-admin/admin-post.php\" method=\"post\" style=\"display:grid;gap:14px\">\n  <input type=\"hidden\" name=\"action\" value=\"ui_contact\" />\n  <input name=\"name\" placeholder=\"Full Name\" required style=\"padding:12px 14px;border:1px solid #cdd9f0;border-radius:10px\" />\n  <input name=\"email\" type=\"email\" placeholder=\"Email Address\" required style=\"padding:12px 14px;border:1px solid #cdd9f0;border-radius:10px\" />\n  <input name=\"phone\" type=\"tel\" placeholder=\"Phone Number\" required style=\"padding:12px 14px;border:1px solid #cdd9f0;border-radius:10px\" />\n  <textarea name=\"message\" rows=\"4\" placeholder=\"Message\" style=\"padding:12px 14px;border:1px solid #cdd9f0;border-radius:10px\"></textarea>\n  <button type=\"submit\" style=\"padding:14px;background:#0A2E65;color:#fff;border:0;border-radius:999px;font-weight:600;cursor:pointer\">Submit Enquiry</button>\n</form>"
